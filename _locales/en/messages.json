  "helpS3Title": { "message": "Scope (URL / DOM Element)" },
  "helpS3Desc": {
    "message": "URL Scope: controls which pages the rule applies to.\nLimit to element: only replaces text within a CSS selector. Use ⊕ Pick to select the element visually."
  },

  "helpS4Title": { "message": "Extra Targets" },
  "helpS4Desc": {
    "message": "By default only visible text nodes are replaced.\nEnable Input fields to also replace input / textarea values; enable Rich text to also replace contenteditable editor content."
